ax:coordStatus a rdfs:Datatype .

ax:discipline a rdfs:Datatype ;
    rdfs:comment "분야" .

ax:documents a rdfs:Property ;
    rdfs:comment "도면 → 시설/공정/장비" .

ax:drawingKind a rdfs:Datatype ;
    rdfs:comment "성격: 스키매틱/좌표도면/참조도면" .

ax:drawingNo a rdfs:Datatype ;
    rdfs:comment "도면번호 (유일키)" .

ax:dxfVerified a rdfs:Datatype ;
    rdfs:comment "DXF 실도면에서 태그 확인됨" .

ax:ingestPolicy a rdfs:Datatype ;
    rdfs:comment "처리: 그래프 편입/SHP 편입/PDF 참조" .

ax:ingestStatus a rdfs:Datatype ;
    rdfs:comment "상태: 편입완료/대기/미수록" .

ax:localXY a rdfs:Datatype ;
    rdfs:comment "도면 로컬좌표 X,Y (실좌표 아님)" .

ax:pdfPage a rdfs:Datatype ;
    rdfs:comment "합본 PDF 페이지 (도면_토목_건축_기계_조경, 301p)" .

ax:powerKW a rdfs:Datatype ;
    rdfs:comment "정격동력 kW" .

ax:quantity a rdfs:Datatype ;
    rdfs:comment "수량" .

ax:spec a rdfs:Datatype ;
    rdfs:comment "형식·규격" .

